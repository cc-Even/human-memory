# ===========================
# LLM API配置
# ===========================

# 阿里云DashScope配置
DASHSCOPE_API_KEY=your_dashscope_api_key_here
DASHSCOPE_EMBEDDING_MODEL=text-embedding-v4
DASHSCOPE_CHAT_MODEL=qwen-plus

# Gemini配置
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_CHAT_MODEL=gemini-pro

# OpenAI配置
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_CHAT_MODEL=gpt-3.5-turbo
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# 默认LLM提供商 (dashscope/gemini/openai)
DEFAULT_LLM_PROVIDER=dashscope

# ===========================
# 数据库配置
# ===========================

# 数据库文件路径
DATABASE_PATH=./memory.db

# ===========================
# 应用配置
# ===========================

# 日志级别 (DEBUG/INFO/WARNING/ERROR)
LOG_LEVEL=INFO

# 日志文件路径
LOG_FILE=./logs/app.log

# 最大日志文件大小(MB)
LOG_MAX_SIZE=10

# 保留日志文件数量
LOG_BACKUP_COUNT=5

# ===========================
# 向量检索配置
# ===========================

# 向量检索Top-K结果数量
VECTOR_SEARCH_TOP_K=5

# 相似度阈值
SIMILARITY_THRESHOLD=0.5

# ===========================
# QueryAgent配置
# ===========================

QUERY_TOP_K=5
QUERY_RELEVANCE_THRESHOLD=0.3
QUERY_MAX_CONTEXT_LENGTH=4000
QUERY_ENABLE_VECTOR_SEARCH=true
QUERY_ENABLE_CONVERSATION=true
QUERY_TEMPERATURE=0.7
QUERY_MAX_TOKENS=1000

# ===========================
# ConsolidateAgent配置
# ===========================

CONSILIDATE_SIMILARITY_THRESHOLD=0.75
CONSILIDATE_TOP_K=5
CONSILIDATE_MAX_MERGE_COUNT=3
CONSILIDATION_INTERVAL_HOURS=24
AUTO_CONSOLIDATE_ENABLED=false
